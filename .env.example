# Telegram Bot Token (Get from @BotFather)
BOT_TOKEN=123456789:ABCDEF...

# Admin IDs (Comma separated list of Telegram IDs)
ADMIN_IDS=[123456789, 987654321]

# Database URL (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ff_bot

# Nix API Token (Get from NixBot)
NIX_API_TOKEN=SEU_TOKEN_AQUI
NIX_BASE_URL=https://salas.nixbot.vip/

# App Settings
DEBUG=False
